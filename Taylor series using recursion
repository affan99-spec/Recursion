
#include <stdio.h>
#include <stdlib.h>
#include <iostream>

using namespace std;

// ************* Taylor series of a number using Recursion *************************

double e(int x, int n)
{
    static double p=1, f=1;
    double r;
    if(n==0)
    {
        return 1;
    }
    r=e(x, n-1);
    p=p*x;
    f=f*n;
    return r+p/f;
}

int main()
{
    double y, z, val;
    cout<<"Enter the value is: ";
    cin>>y>>z;
    val = e(y, z);
    cout<<"Value is: "<<val<<endl;
    return 0;
}
