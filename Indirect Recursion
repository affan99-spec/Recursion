// in this recursion one function is connect to another function by calling own function 

#include <stdio.h>
#include <iostream>

using namespace std;

void funA(int n);
void funB(int n);

void funA(int n) {
    
    if(n>0)
    {
        printf("%d ", n);
        funB(n-1);
    }
}

void funB(int n) 
{
    if(n > 1)
    {
        printf("%d ", n);
        funA(n/2);
    }
}

int main()
{
    int x;
    cout<<"Enter the element : ";
    cin>>x;
    funA(x);
    return 0;
}
