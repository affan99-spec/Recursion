
#include <stdio.h>
#include <iostream>

using namespace std;

void fun(int n) {
    
    if(n>0)
    {
        printf("%d ", n);
        fun(n-1); // function is call in last and after this no code will be written
    }
}

int main()
{
    int x;
    cout<<"Enter the element : ";
    cin>>x;
    fun(x);
    return 0;
}
