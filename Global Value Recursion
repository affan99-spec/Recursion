
#include <stdio.h>
#include <iostream>

using namespace std;

int a=0; // Global Value define 

int fun(int n) {
    
    if(n>0)
    {
        a++;
        return fun(n-1)+a;
    }
    return 0;
}

int main()
{
    int x;
    cout<<"Enter the element : ";
    cin>>x;
    printf("%d ", fun(x));
    return 0;
}
