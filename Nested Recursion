// Nested Recursion function call every time according to the condition 

#include <stdio.h>
#include <iostream>

using namespace std;

int fun(int n) {
    
    if(n>100)
    {
       return n-10;
    } else {
        return fun(fun(n+11));
    }
}

int main()
{
    int x;
    cout<<"Enter the element : ";
    cin>>x;
    fun(x);
    return 0;
}
