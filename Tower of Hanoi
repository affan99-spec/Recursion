
#include <iostream>
#include <stdio.h>
#include <stdlib.h>

using namespace std;

void TOH(int n, char a, char b, char c)
{
    if(n>0)
    {
        TOH(n-1, a, c, b);
        cout<<"Disk moves from "<<a<<" to "<<c<<endl;
        TOH(n-1, b, a, c);
    }
}

int main()
{
    int n;
    char a='A';
    char b='B';
    char c='C';
    cout<<"Enter the value : ";
    cin>>n;
    TOH(n, a, b, c);
    return 0;
}
