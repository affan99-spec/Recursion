
#include <stdio.h>
#include <stdlib.h>
#include <iostream>

using namespace std;

// ************* Taylor series of a number using Recursion *************************

double e(double x, double n)
{
    static double s=1;
    if(n==0)
    {
        return s;
    }
    s = 1+(x/n)*s;
    return e(x, n-1);
}

int main()
{
    double y, z, val;
    cout<<"Enter the value is: ";
    cin>>y>>z;
    val = e(y, z);
    cout<<"Value is: "<<val<<endl;
    return 0;
}

// **************** Taylor series using loop is best ***************************

double e(double x, double n)
{
    double s=1;
    for(;n>0; n--)
    {
        s = 1+(x/n)*s;
    }
    return s;
}

int main()
{
    double y, z, val;
    cout<<"Enter the value is: ";
    cin>>y>>z;
    val = e(y, z);
    cout<<"Value is: "<<val<<endl;
    return 0;
}
